{
  "$schema": "./node_modules/knip/schema-jsonc.json",
  "include": ["files", "exports", "dependencies", "devDependencies"],
  "entry": [
    "package.json",
    "scripts/**/*.mjs",
    "tests/**/*.js",
    "tests/**/*.mjs",
    "tests/fixtures.json",
    "manifests/**/*.json",
    "config/**/*.json",

    // MV3 background entry points. Chrome starts the service worker; Firefox
    // loads the overlay script list from manifests/firefox*.json.
    "src/background/service_worker.js",
    "src/background/auditLog.js",
    "src/background/protectedSiteRegistry.js",
    "src/background/core.js",

    // Manifest-declared content scripts. These are classic scripts loaded in
    // order, so Knip cannot discover the global PWM registrations via imports.
    "src/content/file_drag_guard.js",
    "src/compat/browser_api.js",
    "src/compat/platform.js",
    "src/shared/entropy.js",
    "src/shared/patterns.js",
    "src/shared/placeholders/families.js",
    "src/shared/detection/constants/enterpriseTokens.js",
    "src/shared/detection/constants/providerTokens.js",
    "src/shared/detection/constants/contextRegexes.js",
    "src/shared/detection/contextWindow.js",
    "src/shared/detection/cloudScoring.js",
    "src/shared/detection/enterprise/shared.js",
    "src/shared/detection/enterprise/uncPaths.js",
    "src/shared/detection/enterprise/directoryMetadata.js",
    "src/shared/detection/enterprise/internalNetwork.js",
    "src/shared/detection/enterprise/fileShares.js",
    "src/shared/detection/enterprise/adGroups.js",
    "src/shared/detection/enterprise/hostnames.js",
    "src/shared/detection/enterprise/identity.js",
    "src/shared/detection/enterprise/storageAccounts.js",
    "src/shared/detection/enterprise/azureResourceGroups.js",
    "src/shared/detection/enterprise/cloudResourceNames.js",
    "src/shared/detection/enterprise/index.js",
    "src/shared/detection/providers/azure.js",
    "src/shared/detection/providers/azureIds.js",
    "src/shared/detection/providers/aws.js",
    "src/shared/detection/providers/gcp.js",
    "src/shared/detection/providers/otcOpenStack.js",
    "src/shared/detection/providers/kubernetes.js",
    "src/shared/detection/providers/genericEndpoints.js",
    "src/shared/detection/providers/index.js",
    "src/shared/detection/urlUserinfo.js",
    "src/shared/ai/classifier.js",
    "src/shared/aiCandidateGate.js",
    "src/shared/detector.js",
    "src/shared/placeholders.js",
    "src/shared/ipClassification.js",
    "src/shared/ipDetection.js",
    "src/shared/networkHierarchy.js",
    "src/shared/placeholderAllocator.js",
    "src/shared/sessionMapStore.js",
    "src/shared/knownSecretReuse.js",
    "src/shared/transformOutboundPrompt.js",
    "src/shared/transformOutboundPromptWithAi.js",
    "src/shared/redactor.js",
    "src/shared/fileLimits.js",
    "src/shared/fileTypeRegistry.js",
    "src/shared/fileExtractors.js",
    "src/shared/fileScanner.js",
    "src/shared/streamingFileRedactor.js",
    "src/shared/protected_sites.js",
    "src/shared/policy.js",
    "src/content/composer/chatgptComposerSync.js",
    "src/content/composer/chatgptLargePasteOrchestration.js",
    "src/content/composer/geminiEditorPasteOrchestration.js",
    "src/content/composer/fallbackSendKeyOrchestration.js",
    "src/content/composer/typedSecretScanOrchestration.js",
    "src/shared/runtime_scripts.js",

    // Scanner-only OCR classic scripts are loaded from scanner.html, not modules.
    "src/shared/ocr/ocrRuntime.js",
    "src/shared/ocr/ocrWorker.js",
    "src/shared/pdfRedactor.js",
    "src/shared/docxRedactor.js",
    // Phase 16A proof-only XLSX generator. Not wired into scanner or
    // protected-site uploads until a later phase.
    "src/shared/xlsxRedactor.js",
    "src/shared/scannerOcr.js",
    "src/shared/imageRedactor.js",

    "src/content/composer_helpers.js",
    "src/content/file_paste_helpers.js",
    "src/content/file_handoff_state.js",
    "src/content/file_handoff_pending.js",
    "src/content/file_handoff_flow.js",
    "src/content/input/rewriteVerificationText.js",
    "src/content/composer/replayVerification.js",
    "src/content/files/fileTransferPolicy.js",
    "src/content/files/fileExtractionSessionCache.js",
    "src/content/files/protectedSiteOcrBroker.js",
    "src/content/files/contentFileExtractionPipeline.js",
    "src/content/files/fileTypeSupport.js",
    "src/content/adapters/hostMatching.js",
    "src/content/adapters/chatgptAdapter.js",
    "src/content/adapters/openaiAdapter.js",
    "src/content/adapters/geminiDiagnosticsAdapter.js",
    "src/content/adapters/geminiAdapter.js",
    "src/content/adapters/geminiUploadDiscovery.js",
    "src/content/adapters/geminiFileHandoff.js",
    "src/content/adapters/claudeAdapter.js",
    "src/content/adapters/grokAdapter.js",
    "src/content/adapters/grokFileHandoff.js",
    "src/content/adapters/xAdapter.js",
    "src/content/adapters/whatsappAdapter.js",
    "src/content/adapters/index.js",
    "src/content/whatsapp/whatsappCapabilities.js",
    "src/content/whatsapp/whatsappTextFlow.js",
    "src/content/whatsapp/whatsappSelectors.js",
    "src/content/adapters/geminiFallbackWriter.js",
    "src/content/diagnostics/safeSnapshots.js",
    "src/content/diagnostics/fileDebugMetadata.js",
    "src/content/files/fileProcessingUi.js",
    "src/content/files/fileAttachPipeline.js",
    "src/content/files/sanitizedFileBatchProcessor.js",
    "src/content/files/fileHandoffVerification.js",
    "src/content/files/fileInputPreparation.js",
    "src/content/files/fileHandoffDiscovery.js",
    "src/content/files/sanitizedFileHandoff.js",
    "src/content/files/fileDropInterception.js",
    "src/content/files/fileInputInterception.js",
    "src/content/files/multiFileInsertOrchestration.js",
    "src/content/files/streamingFileInsertOrchestration.js",
    "src/content/files/localFileReadOrchestration.js",
    "src/content/files/localFileAttachPreflightOrchestration.js",
    "src/content/files/localFileSanitizationOrchestration.js",
    "src/content/files/sanitizedFileInsertOrchestration.js",
    "src/content/files/pendingSanitizedFileHandoff.js",
    "src/content/rehydration/placeholderRehydrator.js",
    "src/content/rehydration/responseObserver.js",
    "src/content/rehydration/revealController.js",
    "src/content/diagnostics/debugLogger.js",
    "src/content/diagnostics/contentDebugFacade.js",
    "src/content/ui/contentModalUi.js",
    "src/content/ui/contentStatusUi.js",
    "src/content/bootstrap/eventBindings.js",
    "src/content/content.js",
    "src/content/overlay.css",
    "src/content/protected_site_ocr_broker.html",
    "src/content/protected_site_ocr_broker_page.js",

    // Extension pages are loaded from manifests, popup navigation, or tests;
    // their scripts are browser classic scripts, not module imports.
    "src/popup/popup.html",
    "src/popup/popup.css",
    "src/popup/popup.js",
    "src/options/options.html",
    "src/options/options.css",
    "src/options/options.js",
    "src/scanner/scanner.html",
    "src/scanner/scanner.css",
    "src/scanner/scanner.js",
    "src/ui/reveal_panel.html",
    "src/ui/reveal_panel.css",
    "src/ui/reveal_panel.js"
  ],
  "project": [
    "src/**/*.{js,html,css}",
    "tests/**/*.{js,mjs,json,txt}",
    "scripts/**/*.mjs",
    "manifests/**/*.json",
    "config/**/*.json",
    "*.config.mjs"
  ],
  "ignore": [
    "src/shared/ocr/tesseract-core/tesseract-core.js"
  ],
  "ignoreDependencies": [
    // The build and prepare scripts copy ONNX Runtime browser assets from
    // node_modules by path; there is no static JS import for Knip to follow.
    "onnxruntime-web"
  ]
}
