{
  "name": "leakguard",
  "version": "1.5.0",
  "private": true,
  "description": "Local-first secret redaction engine for LLM chat UIs",
  "scripts": {
    "icons:export": "node scripts/export-icons.mjs",
    "prepare:build": "node scripts/prepare-build.mjs",
    "test": "npm run prepare:build && node scripts/run-tests.mjs",
    "bench:redaction:profile": "node -e \"process.env.LEAKGUARD_BENCH_PROFILE='1'; process.env.LEAKGUARD_BENCH_ITERATIONS=process.env.LEAKGUARD_BENCH_ITERATIONS||'12'; import('./tests/performance/redaction-benchmark.mjs')\"",
    "build": "npm run build:all",
    "prebuild:chrome": "npm run prepare:build",
    "build:chrome": "node scripts/build-extension.mjs --browser chrome --mode consumer",
    "prebuild:chrome-enterprise": "npm run prepare:build",
    "build:chrome-enterprise": "node scripts/build-extension.mjs --browser chrome --mode enterprise",
    "prebuild:firefox": "npm run prepare:build",
    "build:firefox": "node scripts/build-extension.mjs --browser firefox --mode consumer",
    "prebuild:firefox-enterprise": "npm run prepare:build",
    "build:firefox-enterprise": "node scripts/build-extension.mjs --browser firefox --mode enterprise",
    "build:all": "npm run prepare:build && node scripts/build-all.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "onnxruntime-web": "1.25.1"
  }
}
