{
  "type": "object",
  "properties": {
    "enterpriseMode": {
      "type": "boolean"
    },
    "allowReveal": {
      "type": "boolean"
    },
    "allowUserOverride": {
      "type": "boolean"
    },
    "allowProtectionPause": {
      "type": "boolean"
    },
    "protectionPauseMaxMinutes": {
      "type": "number",
      "minimum": 0,
      "maximum": 60
    },
    "protectionPauseRequiresUserAction": {
      "type": "boolean"
    },
    "allowUserAddedSites": {
      "type": "boolean"
    },
    "allowSiteRemoval": {
      "type": "boolean"
    },
    "blockHttpSecrets": {
      "type": "boolean"
    },
    "redactHttpAggressively": {
      "type": "boolean"
    },
    "aiAssistEnabled": {
      "type": "boolean"
    },
    "allowFeedback": {
      "type": "boolean"
    },
    "defaultAction": {
      "type": "string",
      "enum": ["redact", "block"]
    },
    "defaultDestinationAction": {
      "type": "string",
      "enum": ["allow", "redact", "block"]
    },
    "auditMode": {
      "type": "string",
      "enum": ["off", "metadata-only"]
    },
    "auditRetentionDays": {
      "type": "number",
      "minimum": 1,
      "maximum": 365
    },
    "strictPolicyLoad": {
      "type": "boolean"
    },
    "managedProtectedSites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "destinationPolicies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "match": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": ["allow", "redact", "block"]
          }
        },
        "required": ["match", "action"]
      }
    },
    "approvedDestinations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockedDestinations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
