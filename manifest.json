{
  "manifest_version": 3,
  "name": "LeakGuard",
  "version": "1.0.0",
  "description": "Local-only prompt protection for secrets and sensitive network data before they reach AI chat sites.",
  "permissions": ["storage", "scripting", "activeTab"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_title": "LeakGuard",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/*"
      ],
      "js": [
        "shared/entropy.js",
        "shared/patterns.js",
        "shared/detector.js",
        "shared/placeholders.js",
        "shared/ipClassification.js",
        "shared/ipDetection.js",
        "shared/networkHierarchy.js",
        "shared/placeholderAllocator.js",
        "shared/sessionMapStore.js",
        "shared/transformOutboundPrompt.js",
        "shared/redactor.js",
        "shared/protected_sites.js",
        "content/composer_helpers.js",
        "content/content.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
